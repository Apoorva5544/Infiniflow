# ── Required ───────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── Security (change to a long random string in production) ───────────────────
JWT_SECRET=change-this-super-secret-key-in-production

# ── Database (SQLite default, swap for PostgreSQL in prod) ────────────────────
DATABASE_URL=sqlite:///./backend/infiniflow.db

# ── Redis (used by Celery for async task queue) ───────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=your_redis_password_if_any

# ── Vector Store ───────────────────────────────────────────────────────────────
CHROMA_PATH=./chroma_db

# ── Optional ───────────────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# SENTRY_DSN=https://...
# LOG_LEVEL=INFO
